# MatesX Environment Configuration

# 阿里百炼平台秘钥 (DashScope API Key)
# 请到阿里云百炼开发平台开通并获取: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=

# matesx.cn授权平台秘钥
# 从 matesx.cn 获取，用于新建形象
MatesX_key=

# 腾讯 TTS 配置 (可选，只有当 USE_TENCENT_TTS 为 True 时才需要)
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_APP_ID=
